# Backend Environment Variables

# Porta do servidor
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oficina_app_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=development

# SEFAZ/NF-e Integration
SEFAZ_ENVIRONMENT=homologacao
SEFAZ_CERTIFICATE_PATH=./certs/certificado.p12
SEFAZ_CERTIFICATE_PASSWORD=your_certificate_password

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# AWS S3 (opcional para armazenamento)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
